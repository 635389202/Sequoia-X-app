<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="135"
                android:centerColor="#D7352C"
                android:endColor="#A91414"
                android:startColor="#F05A4A"
                android:type="linear" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="315"
                android:endColor="#55168C4A"
                android:startColor="#00168C4A"
                android:type="linear" />
        </shape>
    </item>
    <item
        android:bottom="12dp"
        android:left="12dp"
        android:right="12dp"
        android:top="12dp">
        <shape android:shape="rectangle">
            <corners android:radius="28dp" />
            <solid android:color="#26FFFFFF" />
            <stroke
                android:width="1dp"
                android:color="#44FFFFFF" />
        </shape>
    </item>
</layer-list>
